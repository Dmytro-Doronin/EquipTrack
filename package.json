    "type": "commonjs",
    "main": "index.js",
    "scripts": {
        "lint:client": "npm --prefix client run lint",
        "lint:fix:client": "npm --prefix client run lint:fix",
        "format": "prettier --write \"client/**/*.{js,jsx,ts,tsx,json,md,html,css,scss}\"",
        "format:check": "prettier --check \"client/**/*.{js,jsx,ts,tsx,json,md,html,css,scss}\"",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.1"
    }
}
